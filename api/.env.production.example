# API façade Kelentane — variables de PRODUCTION (VPS).
# Copier en `api/.env.production` (gitignoré) et renseigner. Secrets serveur only.

PORT=3000

# --- Traccar (interne au réseau Docker) ---
# Laissé ici pour référence ; le docker-compose le SURCHARGE à http://traccar:8082.
TRACCAR_URL=http://traccar:8082
# Compte admin Traccar (créé au 1er accès sur l'UI http://<VPS>:8082).
TRACCAR_USER=admin@kelentane.local
TRACCAR_PASS=change-me

# --- Supabase (base app) ---
SUPABASE_URL=https://bgkbkjbjahgmfxcsrqmk.supabase.co
# service_role = SECRET, réservé serveur (jointures, isolation, WS).
SUPABASE_SERVICE_ROLE_KEY=change-me-secret
# publishable = PUBLIQUE (vérif mot de passe compte pour commandes sensibles).
SUPABASE_PUBLISHABLE_KEY=sb_publishable_OK6XH0PUlBea25Qct6RBRw_54eFe8vN
