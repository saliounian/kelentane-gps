# API façade Kelentane — variables serveur UNIQUEMENT (jamais dans le mobile).
# Copier en `.env` (gitignoré) et renseigner.

PORT=3000

# --- Traccar (cœur GPS, non exposé au mobile) ---
# En local via infra/traccar/docker-compose.yml : http://localhost:8082
TRACCAR_URL=http://localhost:8082
TRACCAR_USER=admin@kelentane.local
TRACCAR_PASS=change-me

# --- Supabase (base app) ---
# URL + service_role : le service_role est SECRET, réservé au serveur.
SUPABASE_URL=https://bgkbkjbjahgmfxcsrqmk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me-secret
